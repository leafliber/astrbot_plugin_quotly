{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "font_dir": {
      "type": "string",
      "description": "字体目录路径",
      "default": "assets/fonts"
    },
    "avatar_size": {
      "type": "integer",
      "description": "头像大小（像素）",
      "default": 50,
      "minimum": 20,
      "maximum": 200
    },
    "background_color": {
      "type": "string",
      "description": "背景颜色（十六进制）",
      "default": "#ffffff"
    },
    "bubble_color": {
      "type": "string",
      "description": "气泡背景颜色（十六进制）",
      "default": "#f5f5f5"
    }
  }
}
